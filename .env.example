# Copy to backend/.env (or export in your shell). All values below are the
# offline-safe defaults — the demo runs with zero external services or keys.

# LLM step mode: mock (deterministic, offline) | live (Anthropic API)
LLM_MODE=mock

# Data ingestion mode: cache (data/cache only) | live (GDELT/yfinance/AIS)
DATA_MODE=cache

# Only needed when LLM_MODE=live
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Free key from https://aisstream.io — enables the real live-AIS vessel feed
# (Strait of Hormuz, Bab-el-Mandeb, Indian west coast). Without it the map uses
# a geographically-grounded synthetic fixture, clearly labelled "simulated".
AISSTREAM_API_KEY=

# Override to point at Postgres in production; default is local SQLite.
# DATABASE_URL=postgresql+psycopg://sentinel:sentinel@localhost:5432/sentinel
